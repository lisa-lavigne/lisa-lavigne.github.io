                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "\"¡El objetivo, siempre el objetivo!\"",
                          "lineHeight": 1.4,
                          "fontFamily": "TAN Meringue",
                          "fontSize": 22,
                          "fontWeight": "normal",
