                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "\"Tu empresa no debe ser una prisión, sino un trampolín.\"",
                          "lineHeight": 1.4,
                          "fontFamily": "TAN Meringue",
                          "fontSize": 22,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        },
                        {
                          "type": "text",
                          "id": "0Bdfr",
                          "name": "q3desc",
                          "fill": "$gris-texte",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Creaste tu empresa para darte libertad, no para estar sumergido/a en tareas. Juntos, implementamos estrategias que liberan tiempo y energía.",
                          "lineHeight": 1.6,
                          "fontFamily": "TT Commons Pro",
                          "fontSize": 16,
