                      "padding": 32,
                      "children": [
                        {
                          "type": "icon_font",
                          "id": "ttXFF",
                          "name": "epi2",
                          "width": 32,
                          "height": 32,
                          "iconFontName": "heart-handshake",
                          "iconFontFamily": "lucide",
                          "fill": "$corail"
                        },
                        {
                          "type": "text",
                          "id": "0duuJ",
                          "name": "q2text",
                          "fill": "$bleu-fonce",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "\"¡Se pule!\"",
                          "lineHeight": 1.4,
                          "fontFamily": "TAN Meringue",
                          "fontSize": 22,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        },
                        {
                          "type": "text",
                          "id": "EZqrL",
                          "name": "q2desc",
                          "fill": "$gris-texte",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Porque cada acción que realizas puede ser reutilizada y optimizada. Una buena idea, un buen contenido, un buen proceso: se adapta, se mejora, se sistematiza. Nada debe perderse.",
                          "lineHeight": 1.6,
                          "fontFamily": "TT Commons Pro",
                          "fontSize": 16,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                },
