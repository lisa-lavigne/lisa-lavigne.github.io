                          "fill": "$gris-texte",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Dispersarse es fácil. Pero si cada acción está guiada por un objetivo preciso, todo se vuelve más claro. Mi rol es recentrarte en cada etapa.",
