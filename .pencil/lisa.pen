                          "fill": "$corail"
                        },
                        {
                          "type": "text",
                          "id": "C45nn",
                          "name": "q1text",
                          "fill": "$bleu-fonce",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "\"Si sabes algo pero no lo aplicas, entonces realmente no lo sabes.\"",
                          "lineHeight": 1.4,
                          "fontFamily": "TAN Meringue",
                          "fontSize": 22,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        },
                        {
                          "type": "text",
                          "id": "X6ws9",
                          "name": "q1desc",
                          "fill": "$gris-texte",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Demasiado a menudo acumulamos conocimientos sin ponerlos en práctica. Mi rol es escucharte, desafiarte y ayudarte a pasar a la acción de manera concreta.",
                          "lineHeight": 1.6,
                          "fontFamily": "TT Commons Pro",
                          "fontSize": 16,
